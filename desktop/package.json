{
  "name": "desktop-agent",
  "version": "1.0.0",
  "description": "Desktop GUI for Qwen-Agent — cross-application automation with VLM",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "agent:build": "powershell -ExecutionPolicy Bypass -File ../scripts/build-agent.ps1",
    "dist": "powershell -ExecutionPolicy Bypass -File ../scripts/package-windows.ps1",
    "dist:dir": "npm run agent:build && npm run build && electron-builder --dir"
  },
  "devDependencies": {
    "@solidjs/router": "^0.13.6",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.3.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.2",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-solid": "^2.10.2"
  },
  "allowScripts": {
    "electron@32.3.3": true,
    "esbuild@0.21.5": true
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.desktop.agent",
    "productName": "Desktop Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/agent",
        "to": "agent",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Desktop Agent"
    }
  }
}
